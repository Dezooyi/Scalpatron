# Jupiter API (Price Feed & Trading)
# Rate Limit: 100 Requests/Minute (Free Tier)
# Docs: https://dev.jup.ag/portal/rate-limit
JUPITER_URL=https://price.jup.ag/v6/price
JUPITER_ULTRA_URL=https://lite.jup.ag/ultra/v1/

# Price Feed Konfiguration
# Provider: 'dexscreener' (empfohlen für Devnet/Test), 'jupiter' (Mainnet), 'birdeye', 'custom'
# Hinweis: Jupiter Price API funktioniert nur mit Mainnet-Tokens
PRICE_FEED_PROVIDER=dexscreener
# Tickrate: Wie oft pro Token abgefragt wird (ms)
PRICE_FEED_TICKRATE_MS=3000
# Request Interval: Mindestabstand zwischen API-Calls (Rate Limiting, ms)
# DexScreener: globaler Mindestabstand zwischen ALLEN Token-Requests
# Formel: REQUEST_INTERVAL = TICKRATE_MS / Anzahl_aktiver_Bots
# Beispiel 6 Bots: 3000ms / 6 = 500ms pro Slot → jeder Bot ~alle 3s ein Update
PRICE_FEED_REQUEST_INTERVAL_MS=3000
# Max Retries bei 429/Netzwerk-Fehlern
PRICE_FEED_MAX_RETRIES=4
# Custom URL (nur wenn PRICE_FEED_PROVIDER=custom)
# PRICE_FEED_CUSTOM_URL=http://localhost:3001/price

# Server Performance
# SSE_THROTTLE_MS: Mindestabstand zwischen State-Broadcasts (ms)
# Formel: max(500, PRICE_FEED_TICKRATE_MS / 2)
# Bei hoher Bot-Anzahl (>10) auf 1000ms erhöhen
SERVER_SSE_THROTTLE_MS=100

# Response Cache TTLs (ms)
# BOT_LIST_CACHE: Caching für GET /api/bots
BOT_LIST_CACHE_MS=1000
# LIVEFEED_CACHE: Caching für GET /api/bot/:id/livefeed
LIVEFEED_CACHE_MS=5000

# Body Parser Cache (ms)
# Verhindert doppeltes Parsing bei schnellen Repeat-Requests
BODY_PARSE_CACHE_MS=100

OLLAMA_URL=http://localhost:11434
OLLAMA_PROVIDER=opencode
OLLAMA_MODEL=opencode/minimax-m2.5-free
