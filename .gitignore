# ===========================================
# Scalpatron .gitignore
# ===========================================
# WICHTIG: Diese Datei schützt sensible Daten!
# ===========================================

# --- SENSIBLE DATEN (NIEMALS COMMitten!) ---
.env
.env.local
.env.*.local
.env.example
*.pem
*.key

# --- Wallet & Private Keys ---
wallet.json
wallet.key
*.wallet
keypair.json

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# --- Logs ---
logs/
*.log
logs/*.log
logs/*.jsonl

# --- Database ---
*.sqlite
*.sqlite3
*.db
data/*.jsonl
data/prices.jsonl

# --- IDE & Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Build Outputs ---
dist/
build/
frontend/dist/
frontend/build/

# --- Temporary Files ---
tmp/
temp/
*.tmp
*.bak

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Testing ---
coverage/
.nyc_output/

# --- Documentation (optional) ---
# .docs/ (wenn nicht benötigt)
# screenshots/

# --- Backup Files ---
*.backup
*.bak

# --- User Notes (persönliche Notizen, nicht syncen) ---
"User Notes"/
.gitignore
data/scalpatron.db-shm
data/scalpatron.db-wal
